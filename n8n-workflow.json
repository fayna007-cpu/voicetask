        "message": "=<div dir=\"rtl\" style=\"font-family:Arial,sans-serif;max-width:520px;margin:auto;background:#f9f9fb;border-radius:12px;overflow:hidden\">\n  <div style=\"background:#1a1a1a;padding:24px 28px\">\n    <h2 style=\"color:white;margin:0;font-size:20px\">📅 המשימה נוספה לגוגל קלנדר!</h2>\n  </div>\n  <div style=\"padding:24px 28px\">\n    <table style=\"width:100%;border-collapse:collapse\">\n      <tr><td style=\"padding:8px 0;color:#555;width:100px\"><b>משימה</b></td><td style=\"padding:8px 0;font-size:16px\">{{ $('עיבוד נתונים').item.json.text }}</td></tr>\n      <tr><td style=\"padding:8px 0;color:#555\"><b>קטגוריה</b></td><td style=\"padding:8px 0\">{{ $('עיבוד נתונים').item.json.category }}</td></tr>\n      <tr><td style=\"padding:8px 0;color:#555\"><b>תאריך</b></td><td style=\"padding:8px 0\">{{ new Date($('עיבוד נתונים').item.json.datetime).toLocaleString('he-IL') }}</td></tr>\n    </table>\n  </div>\n  <div style=\"padding:12px 28px;background:#f0f0f0;font-size:12px;color:#888\">נשלח אוטומטית מ-VoiceTask</div>\n</div>"
      }
