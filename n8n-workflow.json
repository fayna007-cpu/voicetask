        "calendar": {"mode": "id", "value": "c5caabcb206401f369c59c985274f14ad284c3ff899fcc1d93bbd4e58213aeae@group.calendar.google.com"},
        "start": "={{ $('עיבוד נתונים').item.json.datetime }}",
        "end": "={{ $('עיבוד נתונים').item.json.endDatetime }}",
        "additionalFields": {
          "summary": "={{ $('עיבוד נתונים').item.json.text }}",
          "description": "=קטגוריה: {{ $('עיבוד נתונים').item.json.category }}\nנוצר ב: {{ new Date($('עיבוד נתונים').item.json.createdAt).toLocaleString('he-IL') }}\n\nנוצר מ-VoiceTask 🎤",
          "attendees": [
            {
              "email": "={{ $('עיבוד נתונים').item.json.email }}"
            }
          ]
        }
      }
    },
