        "operation": "delete",
        "calendar": {"mode": "id", "value": "c5caabcb206401f369c59c985274f14ad284c3ff899fcc1d93bbd4e58213aeae@group.calendar.google.com"},
        "eventId": "={{ ($json.body ?? $json).calendarEventId }}"
      }
