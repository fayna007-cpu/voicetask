{
  "name": "VoiceTask - אוטומציה קולית",
  "nodes": [
    {
      "id": "node-webhook",
      "name": "קבלת משימה",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "voicetask",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "node-if",
      "name": "בדיקת פעולה",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": false, "leftValue": "", "typeValidation": "loose"},
          "conditions": [
            {
              "leftValue": "={{ $json.body.action ?? $json.action }}",
              "rightValue": "delete",
              "operator": {"type": "string", "operation": "equals"}
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "node-code",
      "name": "עיבוד נתונים",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 420],
      "parameters": {
        "jsCode": "try {\n  const task = $input.first().json.body ?? $input.first().json;\n\n  const defaultDatetime = () => {\n    const d = new Date();\n    d.setDate(d.getDate() + 1);\n    d.setHours(9, 0, 0, 0);\n    return d.toISOString();\n  };\n\n  const addHour = (dt) =>\n    new Date(new Date(dt).getTime() + 3600000).toISOString();\n\n  const detectCategory = (text) => {\n    if (!text) return 'כללי';\n    const work     = ['לקוח','פגישה','עבודה','מייל','פרויקט','דוח','ישיבה','זום'];\n    const personal = ['לקנות','בית','משפחה','ילדים','אוכל','רופא','קניות'];\n    if (work.some(k => text.includes(k)))     return 'מקצועי';\n    if (personal.some(k => text.includes(k))) return 'אישי';\n    return 'כללי';\n  };\n\n  const datetime = task.datetime || defaultDatetime();\n\n  const out = {\n    text:        task.text     || '',\n    category:    task.category || detectCategory(task.text),\n    datetime,\n    endDatetime: addHour(datetime),\n    createdAt:   task.createdAt || new Date().toISOString(),\n    completed:   task.completed || false,\n    email:       task.email    || '',\n    action:      task.action   || 'create'\n  };\n\n  return [{ json: out }];\n\n} catch (err) {\n  throw new Error('שגיאה בעיבוד נתונים: ' + err.message);\n}"
      }
    },
    {
      "id": "node-if-email",
      "name": "בדיקת מייל בלבד",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 420],
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": false, "leftValue": "", "typeValidation": "loose"},
          "conditions": [
